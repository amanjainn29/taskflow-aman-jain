# ─────────────────────────────────────────────
#  TaskFlow — Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit .env to git.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=taskflow

# API Server
PORT=8080

# JWT — change this to a long random string in production
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-secret

# Database URL (used directly by Go server — built from above values in docker-compose)
DATABASE_URL=postgres://postgres:password@db:5432/taskflow?sslmode=disable
